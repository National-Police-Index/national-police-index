    "@types/lodash": "^4.17.16",
    "@types/node": "^20.17.32",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.24.0",
    "eslint-config-next": "15.3.0",
    "firebase-admin": "^12.7.0",
    "firebase-tools": "^13.35.1",
    "sass": "^1.86.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
